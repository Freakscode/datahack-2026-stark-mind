# =============================================================================
# STARK-VIX · Backend environment
# Copiar a `.env` y ajustar valores.
# =============================================================================

# --- Database ----------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:stark@localhost:5434/starkvix

# --- LLM providers (ninguno obligatorio en modo local) -----------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
VOYAGE_API_KEY=

# --- Local runtimes ----------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434

# --- Papers fetching --------------------------------------------------------
SERPAPI_KEY=
ARXIV_RATE_LIMIT=3

# --- App config --------------------------------------------------------------
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:8080,http://localhost:8081
DEFAULT_EXECUTION_MODE=local
